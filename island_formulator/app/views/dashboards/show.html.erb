<div class="w-full">
  <div class="flex justify-between items-center mb-8">
    <h1 class="font-bold text-4xl">Welcome back, <%= current_user.email_address.split('@').first.capitalize %>!</h1>
    <div class="text-sm text-gray-500">
      <%= Time.now.strftime("%A, %B %d, %Y") %>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 my-8">
    <div class="bg-white p-7 rounded-3xl shadow-lg border-t-4 border-pink-500">
      <p class="text-gray-500 uppercase text-s font-bold">Ingredients</p>
      <p class="text-4xl font-bold"><%= @stats[:ingredients] %></p>
      <%= link_to "View all →", ingredients_path, class: "text-xs text-pink-400 hover:text-pink-700 mt-2 block" %>
    </div>
    <div class="bg-white p-7 rounded-3xl shadow-lg border-t-4 border-pink-400">
      <p class="text-gray-500 uppercase text-s font-bold">Recipes</p>
      <p class="text-4xl font-bold"><%= @stats[:recipes] %></p>
      <%= link_to "View all →", recipes_path, class: "text-xs text-pink-400 hover:text-pink-700 mt-2 block" %>
    </div>
    <div class="bg-white p-7 rounded-3xl shadow-lg border-t-4 border-pink-300">
      <p class="text-gray-500 uppercase text-s font-bold">Inventory Items</p>
      <p class="text-4xl font-bold"><%= @stats[:inventory] %></p>
      <%= link_to "View all →", inventory_items_path, class: "text-xs text-pink-400 hover:text-pink-700 mt-2 block" %>
    </div>
    <div class="bg-white p-7 rounded-3xl shadow-lg border-t-4 border-pink-200">
      <p class="text-gray-500 uppercase text-s font-bold">Total Batches</p>
      <p class="text-4xl font-bold"><%= @stats[:batches] %></p>
      <%= link_to "View all →", batches_path, class: "text-xs text-pink-400 hover:text-pink-700 mt-2 block" %>
    </div>
  </div>

  <div class="flex flex-col md:flex-row gap-8">
    <!-- Recent Recipes -->
    <div class="flex-1">
      <div class="flex justify-between items-center mb-4">
        <h2 class="font-bold text-2xl text-pink-800">Recent Recipes</h2>
        <%= link_to "New Recipe", new_recipe_path, class: "text-sm bg-pink-50 text-pink-600 px-3 py-1 rounded-full hover:bg-pink-100" %>
      </div>
      <div class="bg-white shadow-lg rounded-2xl divide-y divide-pink-200 border border-pink-100">
        <% @recent_recipes.each do |recipe| %>
          <div class="p-4 flex justify-between items-center hover:bg-pink-50 transition">
            <div>
              <%= link_to recipe.title, recipe, class: "text-pink-700 hover:text-pink-700 font-medium" %>
              <p class="text-xs text-black-400"><%= recipe.product_type %></p>
            </div>
            <span class="text-sm text-black-400"><%= recipe.created_at.strftime("%b %d") %></span>
          </div>
        <% end %>
        <% if @recent_recipes.empty? %>
          <div class="p-8 text-center">
            <p class="text-gray-500 mb-4">No recipes yet.</p>
            <%= link_to "Create your first recipe", new_recipe_path, class: "text-pink-600 font-medium hover:text-pink-800" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Recent Batches -->
    <div class="flex-1">
      <div class="flex justify-between items-center mb-4">
        <h2 class="font-bold text-2xl text-pink-800">Recent Batches</h2>
        <%= link_to "Log Batch", new_batch_path, class: "text-sm bg-rose-100 text-rose-700 px-4 py-1.5 rounded-full hover:bg-rose-200" %>
      </div>
      <div class="bg-white shadow-lg rounded-3xl divide-y divide-pink-100 border border-pink-100">
        <% @recent_batches.each do |batch| %>
          <div class="p-4 flex justify-between items-center hover:bg-pink-100 transition">
            <div>
              <p class="font-medium text-pink-600"><%= batch.recipe.title %></p>
              <p class="text-xs text-gray-500 italic mt-1"><%= batch.notes.truncate(40) if batch.notes.present? %></p>
            </div>
            <div class="text-right">
              <span class="text-sm text-gray-500 block"><%= batch.made_on.strftime("%b %d") %></span>
              <%= link_to "Details", batch, class: "text-xs text-pink-600 hover:text-pink-800 font-medium" %>
            </div>
          </div>
        <% end %>
        <% if @recent_batches.empty? %>
          <div class="p-8 text-center">
            <p class="text-gray-500 mb-4">No batches logged yet.</p>
            <%= link_to "Log your first batch", new_batch_path, class: "text-pink-600 font-medium hover:text-pink-800" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="mt-12 bg-pink-50 p-10 rounded-3xl border-2 border-dashed border-pink-100">
    <h2 class="font-bold text-xl mb-8 text-center text-pink-800">Quick Actions</h2>
    <div class="flex flex-wrap justify-center gap-4">
      <%= link_to "Add New Ingredient", new_ingredient_path, class: "bg-white border border-pink-200 px-6 py-3 rounded-2xl shadow-sm hover:-translate-y-1 transition-all font-medium text-pink-700" %>
      <%= link_to "Record Purchase", new_inventory_item_path, class: "bg-white border border-pink-200 px-6 py-3 rounded-2xl shadow-sm hover:-translate-y-1 transition-all font-medium text-pink-700" %>
      <%= link_to "Create Recipe", new_recipe_path, class: "bg-white border border-pink-200 px-6 py-3 rounded-2xl shadow-sm hover:-translate-y-1 transition-all font-medium text-pink-700" %>
      <%= link_to "Log Production", new_batch_path, class: "bg-white border border-pink-200 px-6 py-3 rounded-2xl shadow-sm hover:-translate-y-1 transition-all font-medium text-pink-700" %>
      <%= link_to "My Favourites", favourites_path, class: "bg-white border border-pink-200 px-6 py-3 rounded-2xl shadow-sm hover:-translate-y-1 transition-all font-medium text-pink-700" %>
    </div>
  </div>
</div>