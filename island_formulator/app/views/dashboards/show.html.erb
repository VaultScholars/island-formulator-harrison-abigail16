<div class="w-full">
  <div class="flex justify-between items-center mb-8">
    <h1 class="font-bold text-4xl text-green-950">🌿 Welcome back, <%= current_user.email_address.split('@').first.capitalize %>!</h1>
    <div class="text-sm text-gray-500">
      <%= Time.now.strftime("%A, %B %d, %Y") %>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 my-8">
    <div class="bg-white p-7 rounded-3xl shadow-md border-t-4 border-green-900">
      <p class="text-gray-500 uppercase text-s font-bold">Ingredients</p>
      <p class="text-4xl font-bold text-green-900"><%= @stats[:ingredients] %></p>
      <%= link_to "View all →", ingredients_path, class: "text-xs text-green-900 hover:text-green-700 mt-2 block" %>
    </div>
    <div class="bg-white p-7 rounded-3xl shadow-md border-t-4 border-green-800">
      <p class="text-gray-500 uppercase text-s font-bold">Recipes</p>
      <p class="text-4xl font-bold text-green-900"><%= @stats[:recipes] %></p>
      <%= link_to "View all →", recipes_path, class: "text-xs text-green-900 hover:text-green-700 mt-2 block" %>
    </div>
    <div class="bg-white p-7 rounded-3xl shadow-md border-t-4 border-green-700">
      <p class="text-gray-500 uppercase text-s font-bold">Inventory Items</p>
      <p class="text-4xl font-bold text-green-900"><%= @stats[:inventory] %></p>
      <%= link_to "View all →", inventory_items_path, class: "text-xs text-green-900 hover:text-green-700 mt-2 block" %>
    </div>
    <div class="bg-white p-7 rounded-3xl shadow-md border-t-4 border-green-600">
      <p class="text-gray-500 uppercase text-s font-bold">Total Batches</p>
      <p class="text-4xl font-bold text-green-900"><%= @stats[:batches] %></p>
      <%= link_to "View all →", batches_path, class: "text-xs text-green-900 hover:text-green-700 mt-2 block" %>
    </div>
  </div>

  <div class="flex flex-col md:flex-row gap-8">
    <!-- Recent Recipes -->
    <div class="flex-1">
      <div class="flex justify-between items-center mb-4">
        <h2 class="font-bold text-2xl text-green-900"> Recent Recipes</h2>
        <%= link_to "New Recipe", new_recipe_path, class: "text-sm bg-green-950/10 text-green-900 px-3 py-1 rounded-full hover:bg-green-950/20" %>
      </div>
      <div class="bg-white shadow-md rounded-2xl divide-y divide-green-900/10 border border-green-900/10">
        <% @recent_recipes.each do |recipe| %>
          <div class="p-4 flex justify-between items-center hover:bg-green-950/5 transition">
            <div>
              <%= link_to recipe.title, recipe, class: "text-green-900 hover:text-green-700 font-medium" %>
              <p class="text-xs text-gray-500"><%= recipe.product_type %></p>
            </div>
            <span class="text-sm text-gray-500"><%= recipe.created_at.strftime("%b %d") %></span>
          </div>
        <% end %>
        <% if @recent_recipes.empty? %>
          <div class="p-8 text-center">
            <p class="text-gray-500 mb-4">No recipes yet.</p>
            <%= link_to "Create your first recipe", new_recipe_path, class: "text-green-900 font-medium hover:text-green-700" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Recent Batches -->
    <div class="flex-1">
      <div class="flex justify-between items-center mb-4">
        <h2 class="font-bold text-2xl text-green-900"> Recent Batches</h2>
        <%= link_to "Log Batch", new_batch_path, class: "text-sm bg-green-900/10 text-green-900 px-4 py-1.5 rounded-full hover:bg-green-900/20" %>
      </div>
      <div class="bg-white shadow-md rounded-3xl divide-y divide-green-900/10 border border-green-900/10">
        <% @recent_batches.each do |batch| %>
          <div class="p-4 flex justify-between items-center hover:bg-green-950/5 transition">
            <div>
              <p class="font-medium text-green-900"><%= batch.recipe.title %></p>
              <p class="text-xs text-gray-500 italic mt-1"><%= batch.notes.truncate(40) if batch.notes.present? %></p>
            </div>
            <div class="text-right">
              <span class="text-sm text-gray-500 block"><%= batch.made_on.strftime("%b %d") %></span>
              <%= link_to "Details", batch, class: "text-xs text-green-900 hover:text-green-700 font-medium" %>
            </div>
          </div>
        <% end %>
        <% if @recent_batches.empty? %>
          <div class="p-8 text-center">
            <p class="text-gray-500 mb-4">No batches logged yet.</p>
            <%= link_to "Log your first batch", new_batch_path, class: "text-green-900 font-medium hover:text-green-700" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="mt-12 bg-green-950/5 p-10 rounded-3xl border-2 border-dashed border-green-900/10">
    <h2 class="font-bold text-xl mb-8 text-center text-green-900">🌿 Quick Actions</h2>
    <div class="flex flex-wrap justify-center gap-4">
      <%= link_to "Add New Ingredient", new_ingredient_path, class: "bg-white border border-green-900/20 px-6 py-3 rounded-2xl shadow-sm hover:-translate-y-1 transition-all font-medium text-green-900" %>
      <%= link_to "Record Purchase", new_inventory_item_path, class: "bg-white border border-green-900/20 px-6 py-3 rounded-2xl shadow-sm hover:-translate-y-1 transition-all font-medium text-green-900" %>
      <%= link_to "Create Recipe", new_recipe_path, class: "bg-white border border-green-900/20 px-6 py-3 rounded-2xl shadow-sm hover:-translate-y-1 transition-all font-medium text-green-900" %>
      <%= link_to "Log Production", new_batch_path, class: "bg-white border border-green-900/20 px-6 py-3 rounded-2xl shadow-sm hover:-translate-y-1 transition-all font-medium text-green-900" %>
      <%= link_to "My Favourites", favourites_path, class: "bg-white border border-green-900/20 px-6 py-3 rounded-2xl shadow-sm hover:-translate-y-1 transition-all font-medium text-green-900" %>
    </div>
  </div>
</div>