<% content_for :title, "Showing ingredient" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-950/10 mb-5 text-green-900 font-medium rounded-xl inline-block" id="notice">🌿 <%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl text-green-950">🌿 Showing ingredient</h1>

  <%= render @ingredient %>

  <%= link_to "Edit this ingredient", edit_ingredient_path(@ingredient), class: "w-full sm:w-auto text-center rounded-xl px-4 py-2.5 bg-green-900/10 hover:bg-green-900/20 inline-block font-medium text-green-900" %>
  <%= link_to "Back to ingredients", ingredients_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-xl px-4 py-2.5 bg-green-900/10 hover:bg-green-900/20 inline-block font-medium text-green-900" %>
  <%= button_to "Destroy this ingredient", @ingredient, method: :delete, form_class: "sm:inline-block mt-2 sm:mt-0 sm:ml-2", class: "w-full rounded-xl px-4 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
</div>

<div class="max-w-2xl mx-auto bg-white shadow-md rounded-2xl overflow-hidden border border-green-900/10">
  <% if @ingredient.photo.attached? %>
    <%= image_tag @ingredient.photo, class: "w-full h-64 object-cover" %>
  <% end %>
  
  <div class="p-6">
    <h1 class="text-3xl font-bold mb-2 text-green-950"><%= @ingredient.name %></h1>
    <p class="text-gray-600 mb-4"><%= @ingredient.category %></p>
    
    <div class="mb-6">
      <h2 class="font-bold text-green-900 uppercase text-xs tracking-wider mb-2">🌿 Description</h2>
      <p class="text-gray-800"><%= @ingredient.description %></p>
    </div>

    <div class="flex space-x-2">
      <%= link_to 'Edit', edit_ingredient_path(@ingredient), class: "bg-green-900 text-white px-4 py-2 rounded-xl hover:bg-green-800" %>
      <%= link_to 'Back', ingredients_path, class: "text-gray-500 py-2" %>
    </div>
  </div>
</div>