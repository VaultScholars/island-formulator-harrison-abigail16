<div class="container mx-auto mt-10 px-5">
  <div class="flex justify-between items-center mb-10">
    <h1 class="text-4xl font-extrabold text-pink-900">My Ingredient Shelf</h1>
    <%= link_to "Add New Ingredient", new_ingredient_path, 
        class: "bg-pink-200 hover:bg-pink-300 text-pink-700 font-bold py-3 px-6 rounded-lg shadow-xl transition duration-200" %>
  </div>

  <div id="ingredients" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    <% @ingredients.each do |ingredient| %>
      <div class="bg-white shadow-xl rounded-xl p-6 border border-gray-100 hover:shadow-3xl transition-shadow duration-300">
        <div class="mb-4">
          <span class="inline-block px-3 py-1 text-xs font-semibold tracking-wide text-pink-600 uppercase bg-pink-200 rounded-full">
            <%= ingredient.category %>
          </span>
        </div>
        
        <% if ingredient.photo.attached? %>
          <%= image_tag ingredient.photo, class: "w-full h-40 object-cover rounded-lg mb-4" %>
        <% end %>

        <h2 class="text-xl font-bold text-pink-700 mb-2"><%= ingredient.name %></h2>
        <p class="text-pink-400 line-clamp-3 mb-4"><%= ingredient.description %></p>
        
        <div class="mt-auto pt-4 border-t border-gray-100 flex justify-between items-center">
          <%= link_to "View Details", ingredient, class: "text-pink-400 font-medium hover:text-pink-200 transition-colors" %>
          <span class="text-gray-400 text-sm">#<%= ingredient.id %></span>
        </div>
      </div>
    <% end %>
  </div>
</div>