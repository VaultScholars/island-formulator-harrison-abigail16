<div class="container mx-auto mt-10 px-5">
  <div class="flex justify-between items-center mb-10">
    <h1 class="text-4xl font-extrabold text-green-950">🌿 My Ingredient Shelf</h1>
    <%= link_to "Add New Ingredient", new_ingredient_path, 
        class: "bg-green-900/10 hover:bg-green-900/20 text-green-900 font-bold py-3 px-6 rounded-xl shadow-md transition duration-200" %>
  </div>

  <div id="ingredients" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    <% @ingredients.each do |ingredient| %>
      <div class="bg-white shadow-md rounded-2xl p-6 border border-green-900/10 hover:shadow-lg transition">
        <div class="mb-4">
          <span class="inline-block px-3 py-1 text-xs font-semibold tracking-wide text-green-900 uppercase bg-green-950/10 rounded-full">
            <%= ingredient.category %>
          </span>
        </div>
        
        <% if ingredient.photo.attached? %>
          <%= image_tag ingredient.photo, class: "w-full h-40 object-cover rounded-xl mb-4" %>
        <% end %>

        <h2 class="text-xl font-bold text-green-900 mb-2"><%= ingredient.name %></h2>
        <p class="text-gray-600 line-clamp-3 mb-4"><%= ingredient.description %></p>
        
        <div class="mt-auto pt-4 border-t border-green-900/10 flex justify-between items-center">
          <%= link_to "View Details", ingredient, class: "text-green-900 font-medium hover:text-green-700 transition-colors" %>
          <span class="text-gray-400 text-sm">#<%= ingredient.id %></span>
        </div>
      </div>
    <% end %>
  </div>
</div>