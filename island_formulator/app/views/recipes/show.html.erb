<% content_for :title, "Showing recipe" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-100 mb-5 text-green-800 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl text-green-900">Showing recipe 🌿</h1>

  <%= render @recipe %>

  <%= link_to "Edit this recipe", edit_recipe_path(@recipe), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-green-100 hover:bg-green-200 inline-block font-medium" %>
  <%= link_to "Back to recipes", recipes_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-green-100 hover:bg-green-200 inline-block font-medium" %>
  <%= button_to "Destroy this recipe", @recipe, method: :delete, form_class: "sm:inline-block mt-2 sm:mt-0 sm:ml-2", class: "w-full rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
   
  <%= link_to "Log a New Batch", new_batch_path(recipe_id: @recipe.id), class: "rounded-lg py-3 px-5 bg-green-800 text-white inline-block font-medium" %>
</div>

<div class="max-w-4xl mx-auto p-6">
  <div class="flex justify-between items-start mb-6">
    <div class="flex items-center space-x-3">
      <h1 class="text-4xl font-bold text-green-900"><%= @recipe.title %> 🌿</h1>

      <% if current_user.favourite_recipes.include?(@recipe) %>
        <%= button_to recipe_favourite_path(@recipe), method: :delete, class: "text-yellow-400 hover:text-yellow-500 text-2xl p-0", form_class: "inline" do %>
          ⭐
        <% end %>
      <% else %>
        <%= button_to recipe_favourite_path(@recipe), method: :post, class: "text-gray-400 hover:text-yellow-500 text-2xl p-0", form_class: "inline" do %>
          ☆
        <% end %>
      <% end %>

  </div>
    <div>
      <span class=" bg-green-100 text-green-800 text-xs px-2 py-1 rounded-full mt-2 font-semibold uppercase tracking-wide">
        <%= @recipe.product_type %>
      </span>
    </div>
    <div class="space-x-2">
      <%= link_to "Edit", edit_recipe_path(@recipe), class: "bg-green-800 text-white px-4 py-2 rounded hover:bg-green-900" %>
      <%= link_to "Back", recipes_path, class: "text-green-700 hover:underline" %>
    </div>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <div class="md:col-span-1">
      <% if @recipe.photo.attached? %>
        <%= image_tag @recipe.photo, class: "w-full h-auto object-cover rounded-xl shadow-lg border-4 border-green-100" %>
      <% else %>
        <div class="w-full h-64 bg-green-100 rounded-xl flex items-center justify-center text-green-500 italic">
          No photo uploaded 
        </div>
      <% end %>
      
      <div class="mt-8 bg-white p-6 rounded-xl shadow-sm border border-green-100">
        <h2 class="text-xl font-bold mb-4 text-green-900 border-b pb-2">Ingredients </h2>
        <ul class="space-y-3">
          <% @recipe.recipe_ingredients.each do |ri| %>
            <li class="flex justify-between items-center">
              <span class="font-medium text-green-800"><%= ri.ingredient.name %></span>
              <span class="text-green-700 bg-green-100 px-2 py-1 rounded text-sm"><%= ri.quantity %></span>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <div class="md:col-span-2">
      <div class="bg-white p-8 rounded-xl shadow-sm border border-green-100 h-full">
        <h2 class="text-2xl font-bold mb-4 text-green-900">Method </h2>
        <div class="prose prose-green max-w-none text-green-800 leading-relaxed">
          <%= simple_format @recipe.method %>
        </div>
      </div>
    </div>
  </div>
</div>