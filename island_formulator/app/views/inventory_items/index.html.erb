<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-100 text-green-800 font-medium rounded-lg inline-block mb-5" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl text-green-900">Inventory 🌿</h1>
    <%= link_to "New Inventory Item", new_inventory_item_path, class: "rounded-lg py-3 px-5 bg-green-200 text-green-900 block font-medium hover:bg-green-300" %>
  </div>

  <div id="inventory_items" class="min-w-full mt-8">
    <div class="overflow-x-auto shadow rounded-lg">
      <table class="min-w-full bg-white">
        <thead class="bg-green-50 border-b">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-green-900 uppercase tracking-wider">Ingredient</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-green-700 uppercase tracking-wider">Brand</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-green-700 uppercase tracking-wider">Size</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-green-700 uppercase tracking-wider">Location</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-green-700 uppercase tracking-wider">Purchased</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-green-700 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-green-100">
          <% @inventory_items.each do |item| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap font-medium text-green-900"><%= item.ingredient.name %></td>
              <td class="px-6 py-4 whitespace-nowrap text-green-700"><%= item.brand %></td>
              <td class="px-6 py-4 whitespace-nowrap text-green-700"><%= item.size %></td>
              <td class="px-6 py-4 whitespace-nowrap text-green-700"><%= item.location %></td>
              <td class="px-6 py-4 whitespace-nowrap text-green-700"><%= item.purchase_date.strftime("%b %d, %Y") %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to "Show", item, class: "text-green-800 hover:text-green-600 mr-3" %>
                <%= link_to "Edit", edit_inventory_item_path(item), class: "text-gray-600 hover:text-green-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>