<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-4 bg-green-950/10 text-green-900 font-medium rounded-xl inline-block mb-5 shadow-sm" id="notice">🌿 <%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl text-green-950">🌿 Batch History</h1>
    <%= link_to "🌿 Log New Batch", new_batch_path, class: "rounded-xl py-3 px-5 bg-green-900/10 text-green-900 block font-medium shadow-sm hover:bg-green-900/20 transition" %>
  </div>

  <div id="batches" class="min-w-full mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
    <% @batches.each do |batch| %>
      <div class="bg-white shadow-md rounded-2xl p-6 border-l-4 border-green-900 hover:shadow-lg transition">
        <div class="flex justify-between items-start">
          <div>
            <h2 class="font-semibold text-xl text-gray-900"><%= batch.recipe.title %></h2>
            <p class="text-sm text-gray-500"><%= batch.made_on.strftime("%B %d, %Y") %></p>
          </div>
          <%= link_to "View Details", batch, class: "text-sm text-green-900 hover:text-green-700 hover:underline font-medium" %>
        </div>
        
        <% if batch.notes.present? %>
          <div class="mt-4 text-gray-700 italic text-sm bg-green-950/5 p-3 rounded-lg">
            "<%= batch.notes.truncate(100) %>"
          </div>
        <% end %>
      </div>
    <% end %>
    
    <% if @batches.empty? %>
      <p class="text-gray-500">🌿 No batches logged yet. Go make something!</p>
    <% end %>
  </div>
</div>