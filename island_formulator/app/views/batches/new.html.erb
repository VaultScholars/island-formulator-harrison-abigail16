<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-4xl text-green-950">🌿 Log a New Batch</h1>

  <%= form_with(model: @batch, class: "contents") do |form| %>
    <% if @batch.errors.any? %>
      <div id="error_explanation" class="bg-green-950/10 text-green-900 px-4 py-3 font-medium rounded-xl mt-4 border border-green-900/20 shadow-sm">
        <h2>🌿 <%= pluralize(@batch.errors.count, "error") %> prohibited this batch from being saved:</h2>
        <ul>
          <% @batch.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="my-5">
      <%= form.label :recipe_id, "Which Recipe?", class: "font-medium text-green-900" %>
      <%= form.collection_select :recipe_id, current_user.recipes, :id, :title, 
          { prompt: "Select a recipe" }, 
          { class: "block shadow-sm rounded-xl border border-green-900/20 focus:ring-2 focus:ring-green-900/30 outline-none px-3 py-2 mt-2 w-full" } %>
    </div>

    <div class="my-5">
      <%= form.label :made_on, "Date Made", class: "font-medium text-green-900" %>
      <%= form.date_field :made_on, class: "block shadow-sm rounded-xl border border-green-900/20 focus:ring-2 focus:ring-green-900/30 outline-none px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="my-5">
      <%= form.label :notes, "Production Notes (How did it go? Any adjustments?)", class: "font-medium text-green-900" %>
      <%= form.text_area :notes, rows: 6, class: "block shadow-sm rounded-xl border border-green-900/20 focus:ring-2 focus:ring-green-900/30 outline-none px-3 py-2 mt-2 w-full", placeholder: "e.g. Added a bit more lavender oil for scent. Consistency is perfect." %>
    </div>

    <div class="inline">
      <%= form.submit "🌿 Log Batch", class: "rounded-xl py-3 px-6 bg-green-900 text-white inline-block font-semibold cursor-pointer shadow-md hover:bg-green-800 transition" %>
      <%= link_to "Cancel", batches_path, class: "ml-2 rounded-xl py-3 px-6 bg-green-900/10 text-green-900 inline-block font-medium hover:bg-green-900/20 transition" %>
    </div>
  <% end %>
</div>