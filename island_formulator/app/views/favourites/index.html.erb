<% content_for :title, "My Favourite Recipes" %>

<div class="max-w-4xl mx-auto p-6">
  <h1 class="text-4xl font-bold mb-6 text-green-950">🌿 My Favourite Recipes</h1>

  <% if @favourite_recipes.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% @favourite_recipes.each do |recipe| %>
        <div class="bg-white rounded-2xl shadow-md p-6 border border-green-900/10 hover:shadow-lg transition">
          <% if recipe.photo.attached? %>
            <%= link_to image_tag(recipe.photo, class: "w-full h-48 object-cover rounded-xl mb-4"), recipe_path(recipe) %>
          <% end %>

          <h2 class="text-2xl font-bold mb-2 text-gray-900"><%= link_to recipe.title, recipe_path(recipe), class: "hover:underline hover:text-green-900" %></h2>
          <span class="inline-block bg-green-950/10 text-green-900 text-xs px-3 py-1 rounded-full uppercase font-semibold">
            <%= recipe.product_type %>
          </span>

          <div class="mt-4 flex justify-between items-center">
            <%= link_to "View", recipe_path(recipe), class: "text-green-900 hover:text-green-700 hover:underline font-medium" %>

            <% if current_user.favourite_recipes.include?(recipe) %>
              <%= button_to recipe_favourite_path(recipe), method: :delete, class: "text-yellow-500 hover:text-yellow-600 p-0", form_class: "inline" do %>
                ⭐
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-500 italic">🌿 You haven’t favourited any recipes yet.</p>
  <% end %>
</div>