<% content_for :title, "My Favourite Recipes" %>

<div class="max-w-4xl mx-auto p-6">
  <h1 class="text-4xl font-bold mb-6">My Favourite Recipes</h1>

  <% if @favourite_recipes.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% @favourite_recipes.each do |recipe| %>
        <div class="bg-white rounded-xl shadow p-6 border border-gray-100">
          <% if recipe.photo.attached? %>
            <%= link_to image_tag(recipe.photo, class: "w-full h-48 object-cover rounded-md mb-4"), recipe_path(recipe) %>
          <% end %>

          <h2 class="text-2xl font-bold mb-2"><%= link_to recipe.title, recipe_path(recipe), class: "hover:underline" %></h2>
          <span class="inline-block bg-green-100 text-green-800 text-xs px-2 py-1 rounded-full uppercase font-semibold">
            <%= recipe.product_type %>
          </span>

          <div class="mt-4 flex justify-between items-center">
            <%= link_to "View", recipe_path(recipe), class: "text-blue-600 hover:underline font-medium" %>

            <%# Allow unfavourite from this page %>
            <% if current_user.favourite_recipes.include?(recipe) %>
              <%= button_to recipe_favourite_path(recipe), method: :delete, class: "text-yellow-400 hover:text-yellow-500 p-0", form_class: "inline" do %>
                ⭐
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-500 italic">You haven’t favourited any recipes yet.</p>
  <% end %>
</div>